# URL del backend FastAPI para WebSocket
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# URL base de la API REST
NEXT_PUBLIC_API_URL=http://localhost:8000

# Nivel de logging (debug | info | warn | error)
# En desarrollo se recomienda 'debug', en producción 'warn' o 'error'
NEXT_PUBLIC_LOG_LEVEL=debug

# Timeout para peticiones HTTP en milisegundos
NEXT_PUBLIC_REQUEST_TIMEOUT=30000

# Cantidad máxima de reintentos para peticiones fallidas
NEXT_PUBLIC_MAX_RETRIES=3